<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS launchd template: trigger run_daily.sh every weekday at 19:00 (after VN market close).

  Install:
    1. Edit ProgramArguments below: replace /Users/USERNAME with your actual path.
    2. Copy this file (without .example) to ~/Library/LaunchAgents/com.tradingagents.dailyrun.plist
    3. launchctl bootstrap gui/$UID ~/Library/LaunchAgents/com.tradingagents.dailyrun.plist
    4. launchctl print gui/$UID/com.tradingagents.dailyrun   (verify loaded)

  Uninstall:
    launchctl bootout gui/$UID/com.tradingagents.dailyrun
    rm ~/Library/LaunchAgents/com.tradingagents.dailyrun.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tradingagents.dailyrun</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/USERNAME/Documents/projects/TradingAgents/dashboard/scripts/run_daily.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>19</integer><key>Minute</key><integer>0</integer><key>Weekday</key><integer>1</integer></dict>
    <dict><key>Hour</key><integer>19</integer><key>Minute</key><integer>0</integer><key>Weekday</key><integer>2</integer></dict>
    <dict><key>Hour</key><integer>19</integer><key>Minute</key><integer>0</integer><key>Weekday</key><integer>3</integer></dict>
    <dict><key>Hour</key><integer>19</integer><key>Minute</key><integer>0</integer><key>Weekday</key><integer>4</integer></dict>
    <dict><key>Hour</key><integer>19</integer><key>Minute</key><integer>0</integer><key>Weekday</key><integer>5</integer></dict>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>TICKERS</key><string>VIC.VN HPG.VN MWG.VN VCB.VN</string>
    <key>PATH</key><string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
  </dict>
  <key>StandardOutPath</key><string>/tmp/tradingagents-dailyrun.out</string>
  <key>StandardErrorPath</key><string>/tmp/tradingagents-dailyrun.err</string>
</dict>
</plist>
